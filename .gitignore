# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's environment, but for an application, you might want to check
#   them in.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different environment settings,
#   it might be better to ignore Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains exact versions, but can be version-controlled.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains exact versions
pdm.lock

# PEP 582; dependency directory created by pdm when pdm.install_in_project is True
